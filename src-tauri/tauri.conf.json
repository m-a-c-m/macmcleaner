{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MACMCleaner",
  "version": "1.0.0",
  "identifier": "es.miguelacm.macmcleaner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MACMCleaner",
        "width": 1172,
        "height": 805,
        "minWidth": 900,
        "minHeight": 650,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' asset: https://asset.localhost data:"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "MACMCleaner",
      "tooltip": "MACMCleaner"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Miguel Angel Colorado Marin",
    "copyright": "Copyright (C) 2025-2026 Miguel Angel Colorado Marin",
    "shortDescription": "MACMCleaner - Privacy-first system cleaner",
    "longDescription": "A safe, open-source, privacy-first system cleaner for Windows. 100% offline, zero data collection.",
    "homepage": "https://miguelacm.es",
    "licenseFile": "../LICENSE",
    "windows": {
      "wix": {}
    }
  },
  "plugins": {}
}
